{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"$CLAUDE_TOOL_INPUT_FILE_PATH\"; [[ \"$f\" == *.cpp || \"$f\" == *.h || \"$f\" == *.hpp ]] && clang-format -i --style=file:$(git -C \"$(dirname \"$f\")\" rev-parse --show-toplevel)/workspace/.clang-format \"$f\" 2>/dev/null || true'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '[[ \"$CLAUDE_TOOL_INPUT_FILE_PATH\" == *\"cmake/deps.cmake\"* ]] && echo \"BLOCK: cmake/deps.cmake is protected. Confirm explicitly before editing.\" && exit 2 || exit 0'"
          }
        ]
      }
    ]
  }
}
