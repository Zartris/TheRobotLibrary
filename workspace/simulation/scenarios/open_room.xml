<mujoco model="open_room">
  <option timestep="0.002" gravity="0 0 -9.81"/>

  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.8 0.8 0.8" rgb2="0.6 0.6 0.6" width="512" height="512"/>
    <material name="grid_mat" texture="grid" texrepeat="8 8" reflectance="0.1"/>
  </asset>

  <worldbody>
    <!-- Ground plane -->
    <geom name="ground" type="plane" size="10 10 0.1" material="grid_mat"/>

    <!-- Walls -->
    <body name="walls" pos="0 0 0.25">
      <geom name="wall_north" type="box" pos="0 5 0" size="5 0.05 0.25" rgba="0.5 0.3 0.2 1"/>
      <geom name="wall_south" type="box" pos="0 -5 0" size="5 0.05 0.25" rgba="0.5 0.3 0.2 1"/>
      <geom name="wall_east" type="box" pos="5 0 0" size="0.05 5 0.25" rgba="0.5 0.3 0.2 1"/>
      <geom name="wall_west" type="box" pos="-5 0 0" size="0.05 5 0.25" rgba="0.5 0.3 0.2 1"/>
    </body>

    <!-- Obstacles -->
    <body name="obstacle1" pos="2 1 0.15">
      <geom name="obs1" type="box" size="0.3 0.3 0.15" rgba="0.8 0.2 0.2 1"/>
    </body>
    <body name="obstacle2" pos="-1 3 0.15">
      <geom name="obs2" type="box" size="0.4 0.2 0.15" rgba="0.8 0.2 0.2 1"/>
    </body>
    <body name="obstacle3" pos="3 -1 0.15">
      <geom name="obs3" type="box" size="0.25 0.35 0.15" rgba="0.8 0.5 0.2 1"/>
    </body>

    <!-- Differential drive robot -->
    <body name="robot_chassis" pos="0 0 0.1">
      <joint name="robot_free" type="free"/>
      <geom name="chassis" type="box" size="0.15 0.1 0.05" mass="2.0" rgba="0.2 0.4 0.8 1"/>

      <!-- Left wheel -->
      <body name="left_wheel" pos="-0.15 0.12 -0.03">
        <joint name="left_wheel_joint" type="hinge" axis="0 1 0"/>
        <geom name="left_wheel_geom" type="cylinder" size="0.05 0.02" rgba="0.3 0.3 0.3 1"
              euler="90 0 0"/>
      </body>

      <!-- Right wheel -->
      <body name="right_wheel" pos="-0.15 -0.12 -0.03">
        <joint name="right_wheel_joint" type="hinge" axis="0 1 0"/>
        <geom name="right_wheel_geom" type="cylinder" size="0.05 0.02" rgba="0.3 0.3 0.3 1"
              euler="90 0 0"/>
      </body>

      <!-- Caster wheel (passive) -->
      <body name="caster" pos="0.12 0 -0.04">
        <geom name="caster_geom" type="sphere" size="0.02" rgba="0.5 0.5 0.5 1"/>
      </body>
    </body>

    <!-- Goal marker -->
    <body name="goal_marker" pos="4 4 0.05">
      <geom name="goal_geom" type="cylinder" size="0.1 0.05" rgba="0.2 0.8 0.2 0.5"/>
    </body>
  </worldbody>

  <actuator>
    <velocity name="left_motor" joint="left_wheel_joint" kv="1"/>
    <velocity name="right_motor" joint="right_wheel_joint" kv="1"/>
  </actuator>
</mujoco>
